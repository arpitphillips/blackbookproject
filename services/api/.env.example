# Copy to .env for local development (loaded via `node --env-file=.env`).
# Connection to the platform PostgreSQL database (see ../../db).
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/blackbook

# HTTP server
PORT=3000
HOST=0.0.0.0

# Logging level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
